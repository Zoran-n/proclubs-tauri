{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProClubs Stats",
  "version": "0.4.1",
  "identifier": "com.codespace.proclubs-tauri",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ProClubs Stats",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzOEUyMjY0QkFEODE1NUEKUldSYUZkaTZaQ0tPZzlKYWxzbjZrMHlINFpnUElIL2V1bFpGRC9Ub3h3SGhkQkEyTWEvUXhmQ2wK",
      "endpoints": [
        "https://github.com/Zoran-n/proclubs-tauri/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Tatsuki",
    "copyright": "Copyright © 2025 Tatsuki. All rights reserved.",
    "shortDescription": "ProClubs Stats — EA FC Pro Clubs statistics tracker",
    "longDescription": "Desktop application to track EA FC Pro Clubs statistics. Built with Tauri.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "nsis": {
      "displayLanguageSelector": false,
      "languages": ["French"],
      "shortcutName": "ProClubs Stats",
      "installerIcon": "icons/icon.ico",
      "installMode": "currentUser"
    }
  }
}
